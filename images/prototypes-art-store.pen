                  "fill": "$text-primary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Ester\nBatllori",
                  "lineHeight": 0.95,
                  "fontFamily": "Funnel Sans",
                  "fontSize": 52,
                  "fontWeight": "normal",
                  "letterSpacing": -1.5
                },
                {
                  "type": "text",
                  "id": "w08R0",
                  "name": "aboutP1",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "I paint intuitively, allowing color and movement to guide the process. My work explores emotions, memories and inner landscapes that are difficult to describe with words.",
                  "lineHeight": 1.7,
                  "fontFamily": "Funnel Sans",
                  "fontSize": 15,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "lZjnx",
                  "name": "aboutP1",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Each painting develops without a fixed plan. Through layers of color and spontaneous gestures, abstract forms emerge that reflect a dialogue between intuition and composition.",
                  "lineHeight": 1.7,
                  "fontFamily": "Funnel Sans",
                  "fontSize": 15,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "h7ekS",
                  "name": "aboutP1",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Inspired by nature, everyday moments and subconscious imagery, I work primarily with acrylics and mixed media on canvas.",
                  "lineHeight": 1.7,
                  "fontFamily": "Funnel Sans",
                  "fontSize": 15,
                  "fontWeight": "normal"
                }
              ]
