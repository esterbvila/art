                  "id": "umJkt",
                  "name": "aboutP1",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "I've been painting for over fifteen years, drawn to the way color and texture can evoke feelings that words never quite capture. My work lives at the intersection of intuition and intention — each piece begins without a plan and finds its own way.",
                  "lineHeight": 1.7,
                  "fontFamily": "Funnel Sans",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "fQqMi",
                  "name": "aboutP2",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Inspired by natural landscapes, shifting light, and the emotional weight of everyday moments, I work primarily with acrylics and mixed media on canvas.",
                  "lineHeight": 1.7,
                  "fontFamily": "Funnel Sans",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            }
