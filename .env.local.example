# ─── Supabase ───────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Service role key is only used server-side (API routes / webhooks)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Stripe ─────────────────────────────────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Webhook secret: Stripe Dashboard → Developers → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Resend (confirmation emails) ────────────────────────────────────────────
# Create a free account at resend.com → API Keys → Create API Key
RESEND_API_KEY=re_SoSqZTng_DZdDEvLMPY9F8cdvxwJzPAga
# Must match a domain verified in your Resend account
# For local testing use: onboarding@resend.dev (delivers only to your own email)
RESEND_FROM_EMAIL=onboarding@resend.dev

# ─── App ─────────────────────────────────────────────────────────────────────
# Used to build Stripe success/cancel redirect URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000
