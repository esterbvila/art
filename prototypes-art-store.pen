              "layout": "vertical",
              "gap": 24,
              "padding": [
                0,
                20,
                40,
                20
              ],
              "children": [
                {
                  "type": "text",
                  "id": "tg3lt",
                  "name": "aboutLabel",
                  "fill": "$text-tertiary",
                  "content": "The Artist",
                  "fontFamily": "Funnel Sans",
                  "fontSize": 12,
                  "fontWeight": "normal",
                  "letterSpacing": 3
                },
                {
                  "type": "text",
                  "id": "BzgCw",
                  "name": "aboutTitle",
                  "fill": "$text-primary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Elena\nMoreau",
                  "lineHeight": 0.95,
                  "fontFamily": "Funnel Sans",
                  "fontSize": 40,
                  "fontWeight": "normal",
                  "letterSpacing": -1.5
                },
                {
                  "type": "text",
                  "id": "umJkt",
                  "name": "aboutP1",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "I've been painting for over fifteen years, drawn to the way color and texture can evoke feelings that words never quite capture. My work lives at the intersection of intuition and intention — each piece begins without a plan and finds its own way.",
                  "lineHeight": 1.7,
                  "fontFamily": "Funnel Sans",
                  "fontSize": 14,
                  "fontWeight": "normal"
                },
