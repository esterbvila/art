              "type": "text",
              "id": "Sn2JH",
              "name": "mplabel",
              "fill": "$text-tertiary",
              "content": "Process",
              "fontFamily": "Funnel Sans",
              "fontSize": 12,
              "fontWeight": "normal",
              "letterSpacing": 3
            },
            {
              "type": "text",
              "id": "FIVb0",
              "name": "mptext",
              "fill": "$text-secondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Built up in thin, translucent layers — each one drying before the next is applied. The texture comes from letting the brush move instinctively, guided by the memory of place rather than a planned composition.",
              "lineHeight": 1.7,
              "fontFamily": "Funnel Sans",
              "fontSize": 14,
              "fontWeight": "normal"
            }
          ]
