                "type": "image",
                "enabled": true,
                "url": "https://images.unsplash.com/photo-1699391197155-78a2b2ccdfd4?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4NDM0ODN8MHwxfHJhbmRvbXx8fHx8fHx8fDE3NzI4MTg0ODZ8&ixlib=rb-4.1.0&q=80&w=1080",
