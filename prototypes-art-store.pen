                    },
                    {
                      "type": "text",
                      "id": "xYHRF",
                      "name": "processLabel",
                      "fill": "$text-tertiary",
                      "content": "Process",
                      "fontFamily": "Funnel Sans",
                      "fontSize": 11,
                      "fontWeight": "normal",
                      "letterSpacing": 2
                    },
                    {
                      "type": "text",
                      "id": "7IJhX",
                      "name": "processText",
                      "fill": "$text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Built up in thin, translucent layers — each one drying before the next is applied. The texture comes from letting the brush move instinctively, guided by the memory of place rather than a planned composition.",
                      "lineHeight": 1.8,
                      "fontFamily": "Funnel Sans",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    }
                  ]
